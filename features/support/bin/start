#!/usr/bin/env ruby
# frozen_string_literal: true

require 'socket'

ports = ARGV.fetch(0).split(',').map(&:to_i)
options = ARGV.drop(1)
environment_output = options.find { |option| option != 'linger' }
linger = options.include?('linger')
closing = false

File.write(environment_output, ENV.fetch('STRING', '')) if environment_output && !environment_output.empty?

Signal.trap 'INT' do
  closing = true
  exit unless linger
end

Signal.trap 'TERM' do
  closing = true
  exit unless linger
end

sleep 1 # Simulate delay

servers = ports.map { |port| TCPServer.new('0.0.0.0', port) }

$stdout.sync = true

Thread.new do
  loop do
    servers.each { |server| server.close if closing && !server.closed? }
    sleep 0.01
  rescue IOError
    nil
  end
end

begin
  servers.each do |server|
    Thread.new(server) do |tcp_server|
      loop do
        conn = tcp_server.accept
        Thread.new(conn) do |socket|
          loop do
            line = socket.readline.strip
            puts "Received line: '#{line}'"

            socket.puts(line)
            puts "Sent line: '#{line}'"
          end
        rescue EOFError
          socket.close
        end
      end
    end
  end

  sleep
rescue IOError, Errno::EBADF
  sleep if linger
end
